# Copy this file to .env and fill in the values you need.

# --- LLM backend -----------------------------------------------------------
# How generation / grading / the eval judge are powered:
#   claude_cli -> shell out to the local `claude` CLI (Claude Max, $0 per call)
#   openai     -> ChatOpenAI (needs OPENAI_API_KEY below)
LLM_BACKEND=claude_cli

# Used when LLM_BACKEND=claude_cli:
CLAUDE_MODEL=sonnet          # sonnet | haiku | opus
CLAUDE_TIMEOUT=180
# CLAUDE_BIN=claude          # path to the claude binary, if not on PATH

# Per-role model overrides. The pre-RAG query gate is a fast classifier, so it
# runs on a cheaper model by default; generation stays on CLAUDE_MODEL.
GATE_MODEL=haiku
# GRADER_MODEL=sonnet        # defaults to CLAUDE_MODEL

# Used when LLM_BACKEND=openai:
# OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0

# --- Embeddings ------------------------------------------------------------
# Commercial embedding (free tier). Required only to build/use the `gemini`
# index. Get a key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-key

# Embedding used by the app / index: minilm | bge | gemini | openai
DEFAULT_EMBEDDING=bge

# Retrieval strategy (or "auto" in the app to let the query gate route per query):
# dense | hybrid | hybrid_rerank | mmr | multi_query | hyde | adaptive_hybrid
DEFAULT_STRATEGY=hybrid

# --- Chunking --------------------------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Retrieval sizing ------------------------------------------------------
TOP_K=5
TOP_SOURCES=3
RERANK_TOP_N=3

# --- Web search (corrective-RAG fallback) ----------------------------------
WEB_SEARCH_RESULTS=3
# Provider: ddg (free, no key) | brave | serper. Auto-falls back to ddg if a
# key is missing or the call fails. SerpAPI is intentionally unsupported (paid).
WEB_SEARCH_PROVIDER=ddg
# BRAVE_API_KEY=          # free tier ~2,000/mo
# SERPER_API_KEY=         # free tier ~2,500 searches
WEB_SEARCH_TIMEOUT=10

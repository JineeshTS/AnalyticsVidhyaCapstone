# Copy this file to .env and fill in the values you need.

# --- LLM backend -----------------------------------------------------------
# How generation / grading / the eval judge are powered:
#   claude_cli -> shell out to the local `claude` CLI (Claude Max, $0 per call)
#   openai     -> ChatOpenAI (needs OPENAI_API_KEY below)
LLM_BACKEND=claude_cli

# Used when LLM_BACKEND=claude_cli:
CLAUDE_MODEL=sonnet          # sonnet | haiku | opus
CLAUDE_TIMEOUT=180
# CLAUDE_BIN=claude          # path to the claude binary, if not on PATH

# Used when LLM_BACKEND=openai:
# OPENAI_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0

# --- Embeddings ------------------------------------------------------------
# Commercial embedding (free tier). Required only to build/use the `gemini`
# index. Get a key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-key

# Embedding used by the app / index: minilm | bge | gemini | openai
DEFAULT_EMBEDDING=bge

# Retrieval strategy: dense | hybrid | hybrid_rerank
DEFAULT_STRATEGY=hybrid

# --- Chunking --------------------------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Retrieval sizing ------------------------------------------------------
TOP_K=5
TOP_SOURCES=3
RERANK_TOP_N=3

# --- Web search (corrective-RAG fallback) ----------------------------------
WEB_SEARCH_RESULTS=3
